<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
 <mapper namespace="spring.ict06team1.midpj.dao.SurveyDAO">
	 <!-- 0. 매핑 -->
	 <resultMap id="surveyMap" type="spring.ict06team1.midpj.dto.SurveyDTO">
	 	<id property="survey_id" column="survey_id"/>
	 	<result property="user_id" column="user_id"/>
	 	<result property="reservation_id" column="reservation_id"/>
	 	<result property="nps_score" column="nps_score"/>
	 	<result property="satisfaction_score" column="satisfaction_score"/>
	 	<result property="inconvenience" column="inconvenience"/>
	 	<result property="info_reliability_score" column="info_reliability_score"/>
	 	<result property="improvements" column="improvements"/>
	 	<result property="surveyDate" column="created_at"/>
	 	
	 	<association property="reservationDTO" javaType="spring.ict06team1.midpj.dto.reservationDTO">
	 		<id property="reservation_id" column="reservation_id"></id>
	 		<result property="user_id" column="user_id"></result>
	 	</association>
	 </resultMap>

	<!-- 1. 설문 등록 -->
	<insert id="insertSurvey" parameterType="spring.ict06team1.midpj.dto.SurveyDTO">
		<selectKey keyProperty="survey_id" resultType="int" order="BEFORE">
			SELECT SEQ_SURVEY.NEXTVAL FROM DUAL
		</selectKey>
		
		INSERT INTO SURVEY (
			survey_id, user_id, reservation_id,
			nps_score, satisfaction_score,
			inconvenience, info_reliability_score, improvements
		) VALUES (
			#{survey_id}, #{user_id}, #{reservation_id},
			#{nps_score}, #{satisfaction_score},
			#{inconvenience}, #{info_reliability_score}, #{improvements}
		)
	</insert>
	
	<!-- 2. 설문 존재 여부 체크 -->
	<select id="checkSurveyExists" parameterType="String" resultType="int">
		SELECT COUNT(*)
		FROM SURVEY
		WHERE reservation_id = #{reservation_id}
	</select>
	
	<!-- 3. 설문 대상 예약 조회 -->
	<select id="getSurveyTargetList" parameterType="String" resultType="spring.ict06team1.midpj.dto.SurveyDTO">
		SELECT *
		FROM RESERVATION
		WHERE user_id = #{user_id}
		AND status = 'COMPLETED'
		AND reservation_id NOT IN (
			SELECT reservation_id FROM SURVEY
		)
		ORDER BY created_at DESC
	</select>
 </mapper>