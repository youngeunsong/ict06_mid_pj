<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
 <mapper namespace="spring.ict06team1.midpj.dao.AdminDAO">  <!-- namespace="패키지명.인터페이스" -->
	 <!-- 0. 매핑 -->
	 <resultMap id="reservationMap" type="spring.ict06team1.midpj.dto.ReservationDTO">
	 	<id property="reservation_id" column="reservation_id"/> <!-- pk -->
	 	<result property="user_id" column="user_id"/>
	 	<result property="place_id" column="place_id"/>
	 	<result property="check_in" column="check_in"/>
	 	<result property="check_out" column="check_out"/>
	 	<result property="visit_time" column="visit_time"/>
	 	<result property="ticket_type" column="ticket_type"/>
	 	<result property="guest_count" column="guest_count"/>
	 	<result property="request_note" column="request_note"/>
	 	<result property="status" column="status"/>
	 	<result property="payment_id" column="payment_id"/>
	 	<result property="resDate" column="created_at"/>
	 	
	 	<association property="placeDTO" javaType="spring.ict06team1.midpj.dto.PlaceDTO">
	 		<id property="place_id" column="place_id"></id>
	 		<result property="place_type" column="place_type"></result>
	 		<result property="name" column="name"></result>
	 		<result property="address" column="address"></result>
	 		<result property="view_count" column="view_count"></result>
	 		<result property="latitude" column="latitude"></result>
	 		<result property="longitude" column="longitude"></result>
	 		<result property="image_url" column="image_url"></result>
	 		<result property="placeRegDate" column="created_at"></result>
	 	</association>
	 </resultMap>

	<!-- 1-1. 예약목록 전체 조회 -->
	<select id="getReservationList" parameterType="map" resultMap="reservationMap">
		SELECT R.reservation_id, R.user_id, R.place_id,
			   TRUNC(R.check_in) AS check_in,
			   TRUNC(R.check_out) AS check_out,
			   R.visit_time, R.ticket_type, R.guest_count,
			   R.request_note, R.status, R.payment_id, R.created_at,
			   P.name, P.address, P.place_type
		FROM RESERVATION R
		LEFT JOIN PLACE P
		ON R.place_id = P.place_id
		<where>
			<if test="keyword != null and keyword != ''">
				(R.user_id LIKE '%'||#{keyword}||'%' OR R.reservation_id LIKE '%'||#{keyword}||'%')
			</if>
			<if test="status != null and status != ''">
				AND R.status = #{status}
			</if>
			<if test="placeType != null and placeType != ''">
				AND P.place_type = #{placeType}
			</if>
		</where>
		ORDER BY R.created_at DESC
	</select>
	
	<!-- 1-2. 예약 상세 조회 -->
	<select id="getReservationDetail" parameterType="String" resultMap="reservationMap">
		SELECT R.reservation_id, R.user_id, R.place_id,
			   TRUNC(R.check_in) AS check_in,
			   TRUNC(R.check_out) AS check_out,
			   R.visit_time, R.ticket_type, R.guest_count,
			   R.request_note, R.status, R.payment_id, R.created_at,
			   P.name, P.address, P.place_type
		FROM RESERVATION R
		LEFT JOIN PLACE P
		ON R.place_id = P.place_id
		WHERE R.RESERVATION_ID = #{reservation_id}
	</select>
	
	<!-- 2-1. 예약상태 변경 -->
	<update id="updateReservationStatus" parameterType="map">
		UPDATE RESERVATION
		SET STATUS = #{status},
			created_at = CURRENT_TIMESTAMP
		WHERE reservation_id = #{resId}
	</update>
	
	<!-- 3-1. 대시보드(기간별 집계) --><!-- 
	<select id="getReservationStatistics" resultMap="reservationMap">
		SELECT
			COUNT(*) AS TOTAL,
			COUNT(CASE WHEN status = 'PENDING' THEN 1 END) AS PENDING,
			COUNT(CASE WHEN status = 'RESERVED' THEN 1 END) AS RESERVED,
			COUNT(CASE WHEN status = 'COMPLETED' THEN 1 END) AS COMPLETED,
			COUNT(CASE WHEN status = 'CANCELLED' THEN 1 END) AS CANCELLED,
			COUNT(CASE WHEN status = 'NOSHOW' THEN 1 END) AS NOSHOW
		  FROM RESERVATION
	 </select> -->
 </mapper> 